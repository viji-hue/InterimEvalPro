# ─────────────────────────────────────────────────────────────────
# EvalPro Backend Environment Variables (TEMPLATE)
# Copy this to .env and fill in your actual values
# NEVER commit .env to git
# ─────────────────────────────────────────────────────────────────

# Trainer credentials (only stored here, never sent to frontend)
TRAINER_NAME=your_trainer_name
TRAINER_CODE=your_trainer_code

# JWT secret for trainer session tokens (use a strong random string)
JWT_SECRET=your_jwt_secret_key_change_this_in_production

# Google Gemini API key (get from https://aistudio.google.com/app/apikey)
# This key must NOT be committed to git — it's in .gitignore
# To get a Gemini API key:
# 1. Go to https://aistudio.google.com/app/apikey
# 2. Click "Create API key"
# 3. Copy the key and paste it below
GEMINI_API_KEY=your_gemini_api_key_here

# Server config
PORT=4000
FRONTEND_URL=http://localhost:5173

# For production, update:
# - FRONTEND_URL to your actual frontend domain
# - JWT_SECRET to a strong random value
# - Use environment variables from your hosting platform (Vercel, Heroku, etc)
